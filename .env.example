# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
# Used for: Agents Platform (voice interview + outbound call agents), TTS/STT.
ELEVENLABS_API_KEY=

# Optional: set if using a specific ElevenLabs Agent (Agents Platform) for intake/calls.
# Find/create agents at https://elevenlabs.io/app/agents
ELEVENLABS_AGENT_ID=

# Required if placing real outbound calls via Twilio/SIP per the challenge brief.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Optional: for programmatic call-list / business discovery (Google Places / Yelp Fusion).
# GOOGLE_PLACES_API_KEY=
# YELP_API_KEY=
