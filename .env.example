# ── ElevenLabs — https://elevenlabs.io/app/settings/api-keys ──────────────
# Agents platform: intake interview + negotiator + persona agents; TTS/STT.
ELEVENLABS_API_KEY=
# Agent IDs (create at https://elevenlabs.io/app/agents; persona agent IDs go in the
# `personas` DB table, not here)
ELEVENLABS_AGENT_ID_NEGOTIATOR=
ELEVENLABS_AGENT_ID_INTAKE=
# Browser copy of ELEVENLABS_AGENT_ID_INTAKE (goes in apps/web/.env.local) — powers the
# <elevenlabs-convai> voice-interview widget on /intake; the agent must be set PUBLIC:
# NEXT_PUBLIC_ELEVENLABS_AGENT_ID_INTAKE=
# Teammates' keys as credit reserve (agents all live on the PRIMARY account/workspace;
# spares are for credit-exhaustion fallback + TTS-only side jobs like video narration):
# ELEVENLABS_API_KEY_SPARE_1=
# ELEVENLABS_API_KEY_SPARE_2=
# ELEVENLABS_API_KEY_SPARE_3=

# ── OpenAI — offline text + bill/EOB vision parsing ───────────────────────
OPENAI_API_KEY=

# ── Supabase — https://supabase.com/dashboard → project settings → API ────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-side (FastAPI) ONLY — never ships to the browser
SUPABASE_DB_URL=                    # postgres connection string (for migrations)
# Browser copies for Next.js (same values as above):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Twilio — real outbound/inbound call legs (native ElevenLabs integration) ──
# NOTE (web-verified): trial accounts can only call ≤5 verified numbers (error 21608).
# Upgrade to paid at H0 and buy all numbers at once.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=                # negotiator's outbound caller ID
